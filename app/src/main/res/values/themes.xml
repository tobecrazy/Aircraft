<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.Aircraft" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor" tools:targetApi="l">?attr/colorPrimaryVariant</item>
        <!-- Customize your theme here. -->
    </style>

    <style name="Theme.Aircraft.Common" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">#252A3A</item>
        <item name="colorPrimaryVariant">#1B1F2B</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="homeAsUpIndicator">@drawable/ic_header_back</item>
        <item name="android:statusBarColor" >#1B1F2B</item>
        <item name="android:windowBackground">#1B1F2B</item>
    </style>

    <!-- Shared game UI styles for cinematic screens -->
    <style name="GameHeader">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">52dp</item>
        <item name="android:background">#161A26</item>
        <item name="android:gravity">center_vertical</item>
    </style>

    <style name="GameHeaderTitle">
        <item name="android:textColor">#00FF88</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:typeface">monospace</item>
        <item name="android:letterSpacing">0.25</item>
    </style>

    <style name="NeonDivider">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">1dp</item>
        <item name="android:background">#4400FF88</item>
    </style>

    <style name="TacticalButton">
        <item name="android:layout_height">38dp</item>
        <item name="android:gravity">center</item>
        <item name="android:letterSpacing">0.15</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:typeface">monospace</item>
    </style>

    <style name="TacticalButton.Accept">
        <item name="android:background">@drawable/btn_accept_bg</item>
        <item name="android:textColor">#0F1118</item>
    </style>

    <style name="TacticalButton.Reject">
        <item name="android:background">@drawable/btn_reject_bg</item>
        <item name="android:textColor">#FF5555</item>
    </style>

    <style name="TransparentTheme" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="colorPrimaryDark">@color/transparent</item>
        <item name="homeAsUpIndicator">@drawable/ic_header_back</item>
        <item name="android:windowBackground">@color/transparent</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowAnimationStyle">@android:style/Animation.Translucent</item>
    </style>

    <style name="TransparentMaterialTheme" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="homeAsUpIndicator">@drawable/ic_header_back</item>
        <item name="android:windowBackground">@color/transparent</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowAnimationStyle">@android:style/Animation.Translucent</item>
        <item name="android:statusBarColor" tools:targetApi="l">@color/transparent</item>
        <item name="android:navigationBarColor" tools:targetApi="o_mr1">@color/transparent</item>
    </style>

    <style name="DialogAnimation">
        <item name="android:windowEnterAnimation">@anim/dialog_enter</item>
        <item name="android:windowExitAnimation">@anim/dialog_exit</item>
    </style>

    <style name="ThemeOverlay.Aircraft.HallOfHeroesBottomSheet" parent="ThemeOverlay.MaterialComponents.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/Widget.Aircraft.HallOfHeroesBottomSheet</item>
        <item name="android:backgroundDimAmount">0.75</item>
    </style>

    <style name="Widget.Aircraft.HallOfHeroesBottomSheet" parent="Widget.MaterialComponents.BottomSheet.Modal">
        <item name="android:background">@android:color/transparent</item>
    </style>

</resources>
