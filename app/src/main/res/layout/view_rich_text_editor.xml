<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Formatting Toolbar -->
    <HorizontalScrollView
        android:id="@+id/rich_toolbar_scroll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#161A26"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="8dp">

            <TextView
                android:id="@+id/rich_btn_bold"
                android:layout_width="40dp"
                android:layout_height="32dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:gravity="center"
                android:text="B"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:typeface="monospace" />

            <View
                android:layout_width="1dp"
                android:layout_height="20dp"
                android:background="#33FFFFFF" />

            <TextView
                android:id="@+id/rich_btn_italic"
                android:layout_width="40dp"
                android:layout_height="32dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:gravity="center"
                android:text="I"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold|italic"
                android:typeface="monospace" />

            <View
                android:layout_width="1dp"
                android:layout_height="20dp"
                android:background="#33FFFFFF" />

            <TextView
                android:id="@+id/rich_btn_underline"
                android:layout_width="40dp"
                android:layout_height="32dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:gravity="center"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:typeface="monospace" />

            <View
                android:layout_width="1dp"
                android:layout_height="20dp"
                android:background="#33FFFFFF" />

            <TextView
                android:id="@+id/rich_btn_size"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:gravity="center"
                android:paddingHorizontal="8dp"
                android:text="@string/rich_text_btn_size"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold"
                android:typeface="monospace" />

            <View
                android:layout_width="1dp"
                android:layout_height="20dp"
                android:background="#33FFFFFF" />

            <TextView
                android:id="@+id/rich_btn_color"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:gravity="center"
                android:paddingHorizontal="8dp"
                android:text="@string/rich_text_btn_color"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold"
                android:typeface="monospace" />

            <View
                android:layout_width="1dp"
                android:layout_height="20dp"
                android:background="#33FFFFFF" />

            <TextView
                android:id="@+id/rich_btn_markdown"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:gravity="center"
                android:paddingHorizontal="8dp"
                android:text="MD"
                android:textColor="#66FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold"
                android:typeface="monospace" />

            <View
                android:layout_width="1dp"
                android:layout_height="20dp"
                android:background="#33FFFFFF" />

            <TextView
                android:id="@+id/rich_btn_html"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:gravity="center"
                android:paddingHorizontal="8dp"
                android:text="HTML"
                android:textColor="#66FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold"
                android:typeface="monospace" />
        </LinearLayout>
    </HorizontalScrollView>

    <View
        android:id="@+id/rich_toolbar_divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#22FFFFFF" />

    <!-- Editor -->
    <EditText
        android:id="@+id/rich_et_editor"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@android:color/transparent"
        android:gravity="top|start"
        android:hint="@string/rich_text_hint"
        android:inputType="textMultiLine|textNoSuggestions"
        android:lineSpacingExtra="4dp"
        android:padding="16dp"
        android:scrollbars="vertical"
        android:textColor="#CDD2E0"
        android:textColorHint="#44FFFFFF"
        android:textSize="14sp"
        android:typeface="monospace" />

</merge>
