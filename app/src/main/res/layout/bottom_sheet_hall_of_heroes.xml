<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/hall_of_heroes_sheet_background"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:paddingHorizontal="24dp"
    android:paddingTop="14dp"
    android:paddingBottom="28dp">

    <View
        android:layout_width="44dp"
        android:layout_height="5dp"
        android:background="@drawable/dialog_sheet_handle_bg" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:background="@drawable/dialog_badge_gold_bg"
        android:fontFamily="monospace"
        android:paddingHorizontal="12dp"
        android:paddingVertical="6dp"
        android:text="@string/hall_of_heroes_badge"
        android:textColor="#FFD9FFEC"
        android:textSize="11sp"
        android:textStyle="bold" />

    <ImageView
        android:id="@+id/image_hall_of_heroes_medal"
        android:layout_width="152dp"
        android:layout_height="152dp"
        android:layout_marginTop="18dp"
        android:contentDescription="@string/hall_of_heroes_medal_content_description"
        android:src="@drawable/ic_hall_of_heroes_medal" />

    <TextView
        android:id="@+id/text_hall_of_heroes_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:fontFamily="monospace"
        android:text="@string/hall_of_heroes_title"
        android:textColor="#7DFFBB"
        android:textSize="24sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/text_hall_of_heroes_message"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:fontFamily="monospace"
        android:gravity="center"
        android:lineSpacingExtra="4dp"
        android:text="@string/hall_of_heroes_message"
        android:textColor="#E6FFFFFF"
        android:textSize="15sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:background="@drawable/dialog_stat_card_bg"
        android:orientation="vertical"
        android:paddingHorizontal="14dp"
        android:paddingVertical="14dp">

        <TextView
            android:id="@+id/text_hall_of_heroes_prompt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:text="@string/hall_of_heroes_prompt"
            android:textColor="#997DFFBB"
            android:textSize="12sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/edit_hero_name"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="10dp"
            android:autofillHints=""
            android:background="@drawable/hall_of_heroes_input_background"
            android:fontFamily="monospace"
            android:gravity="center_vertical"
            android:hint="@string/hall_of_heroes_name_hint"
            android:imeOptions="actionDone"
            android:inputType="textCapWords|textPersonName"
            android:maxLines="1"
            android:paddingHorizontal="16dp"
            android:textColor="#FFFFFF"
            android:textColorHint="#66FFFFFF" />

        <TextView
            android:id="@+id/text_hall_of_heroes_hint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:fontFamily="monospace"
            android:textColor="#88FFFFFF"
            android:textSize="11sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/button_record_hero"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginTop="18dp"
        android:background="@drawable/dialog_button_primary"
        android:fontFamily="monospace"
        android:gravity="center"
        android:text="@string/hall_of_heroes_record_button"
        android:textColor="#13221E"
        android:textSize="14sp"
        android:textStyle="bold" />

</LinearLayout>
