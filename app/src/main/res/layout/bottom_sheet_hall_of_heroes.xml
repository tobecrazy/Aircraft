<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/hall_of_heroes_sheet_background"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:paddingHorizontal="24dp"
    android:paddingTop="14dp"
    android:paddingBottom="28dp">

    <View
        android:layout_width="42dp"
        android:layout_height="4dp"
        android:background="#44FFFFFF" />

    <ImageView
        android:id="@+id/image_hall_of_heroes_medal"
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:layout_marginTop="18dp"
        android:contentDescription="@string/hall_of_heroes_medal_content_description"
        android:src="@drawable/ic_hall_of_heroes_medal" />

    <TextView
        android:id="@+id/text_hall_of_heroes_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:fontFamily="monospace"
        android:text="@string/hall_of_heroes_title"
        android:textColor="#FFD45A"
        android:textSize="22sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/text_hall_of_heroes_message"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:fontFamily="monospace"
        android:gravity="center"
        android:lineSpacingExtra="4dp"
        android:text="@string/hall_of_heroes_message"
        android:textColor="#E6FFFFFF"
        android:textSize="15sp" />

    <TextView
        android:id="@+id/text_hall_of_heroes_prompt"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:fontFamily="monospace"
        android:text="@string/hall_of_heroes_prompt"
        android:textColor="#99FFD45A"
        android:textSize="13sp"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/edit_hero_name"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/hall_of_heroes_input_background"
        android:fontFamily="monospace"
        android:gravity="center_vertical"
        android:hint="@string/hall_of_heroes_name_hint"
        android:imeOptions="actionDone"
        android:inputType="textCapWords|textPersonName"
        android:maxLines="1"
        android:paddingHorizontal="16dp"
        android:textColor="#FFFFFF"
        android:textColorHint="#66FFFFFF" />

    <TextView
        android:id="@+id/button_record_hero"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="18dp"
        android:background="@drawable/dialog_button_primary"
        android:fontFamily="monospace"
        android:gravity="center"
        android:text="@string/hall_of_heroes_record_button"
        android:textColor="#1B1F2B"
        android:textSize="14sp"
        android:textStyle="bold" />

</LinearLayout>
