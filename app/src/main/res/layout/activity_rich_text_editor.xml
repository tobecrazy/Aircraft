<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#0F1118"
        android:fitsSystemWindows="true"
        android:orientation="vertical">

        <!-- Header -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="#161A26"
            android:gravity="center_vertical">

            <ImageButton
                android:id="@+id/btn_back"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:layout_marginStart="4dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/history_cancel"
                android:src="?attr/homeAsUpIndicator" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:letterSpacing="0.25"
                android:text="@string/rich_text_editor_title"
                android:textColor="#00FF88"
                android:textSize="16sp"
                android:textStyle="bold"
                android:typeface="monospace" />
        </RelativeLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#4400FF88" />

        <!-- Formatting Toolbar -->
        <HorizontalScrollView
            android:id="@+id/toolbar_scroll"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#161A26"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="8dp">

                <TextView
                    android:id="@+id/btn_bold"
                    android:layout_width="40dp"
                    android:layout_height="32dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:gravity="center"
                    android:text="B"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:typeface="monospace" />

                <View
                    android:layout_width="1dp"
                    android:layout_height="20dp"
                    android:background="#33FFFFFF" />

                <TextView
                    android:id="@+id/btn_italic"
                    android:layout_width="40dp"
                    android:layout_height="32dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:gravity="center"
                    android:text="I"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold|italic"
                    android:typeface="monospace" />

                <View
                    android:layout_width="1dp"
                    android:layout_height="20dp"
                    android:background="#33FFFFFF" />

                <TextView
                    android:id="@+id/btn_underline"
                    android:layout_width="40dp"
                    android:layout_height="32dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:gravity="center"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:typeface="monospace" />

                <View
                    android:layout_width="1dp"
                    android:layout_height="20dp"
                    android:background="#33FFFFFF" />

                <TextView
                    android:id="@+id/btn_size"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:gravity="center"
                    android:paddingHorizontal="8dp"
                    android:text="@string/rich_text_btn_size"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:typeface="monospace" />

                <View
                    android:layout_width="1dp"
                    android:layout_height="20dp"
                    android:background="#33FFFFFF" />

                <TextView
                    android:id="@+id/btn_color"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:gravity="center"
                    android:paddingHorizontal="8dp"
                    android:text="@string/rich_text_btn_color"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:typeface="monospace" />

                <View
                    android:layout_width="1dp"
                    android:layout_height="20dp"
                    android:background="#33FFFFFF" />

                <TextView
                    android:id="@+id/btn_markdown"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:gravity="center"
                    android:paddingHorizontal="8dp"
                    android:text="MD"
                    android:textColor="#66FFFFFF"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:typeface="monospace" />

                <View
                    android:layout_width="1dp"
                    android:layout_height="20dp"
                    android:background="#33FFFFFF" />

                <TextView
                    android:id="@+id/btn_html"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:gravity="center"
                    android:paddingHorizontal="8dp"
                    android:text="HTML"
                    android:textColor="#66FFFFFF"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:typeface="monospace" />
            </LinearLayout>
        </HorizontalScrollView>

        <View
            android:id="@+id/toolbar_divider"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#22FFFFFF" />

        <!-- Edit Mode: EditText -->
        <EditText
            android:id="@+id/et_editor"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:gravity="top|start"
            android:hint="@string/rich_text_hint"
            android:inputType="textMultiLine|textNoSuggestions"
            android:lineSpacingExtra="4dp"
            android:padding="16dp"
            android:scrollbars="vertical"
            android:textColor="#CDD2E0"
            android:textColorHint="#44FFFFFF"
            android:textSize="14sp"
            android:typeface="monospace" />

        <!-- Preview Mode: WebView -->
        <WebView
            android:id="@+id/wv_preview"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:visibility="gone" />

        <!-- Bottom Bar: Edit / Preview toggle -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#4400FF88" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="#161A26"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/btn_edit_mode"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:background="@drawable/device_info_gauge_bg"
                android:gravity="center"
                android:text="@string/rich_text_mode_edit"
                android:textColor="#00FF88"
                android:textSize="13sp"
                android:textStyle="bold"
                android:typeface="monospace" />

            <TextView
                android:id="@+id/btn_preview_mode"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="16dp"
                android:layout_weight="1"
                android:background="@drawable/device_info_gauge_bg"
                android:gravity="center"
                android:text="@string/rich_text_mode_preview"
                android:textColor="#66FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold"
                android:typeface="monospace" />
        </LinearLayout>

    </LinearLayout>
</layout>
