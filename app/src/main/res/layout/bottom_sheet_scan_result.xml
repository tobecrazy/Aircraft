<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/qr_tool_sheet_background"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:paddingHorizontal="24dp"
    android:paddingTop="14dp"
    android:paddingBottom="28dp">

    <View
        android:layout_width="44dp"
        android:layout_height="5dp"
        android:background="@drawable/dialog_sheet_handle_bg" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:background="@drawable/qr_tool_status_pill_bg"
        android:fontFamily="monospace"
        android:paddingHorizontal="12dp"
        android:paddingVertical="6dp"
        android:text="@string/qr_code_tool_scan_result"
        android:textColor="#00FF88"
        android:textSize="11sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:background="@drawable/dialog_stat_card_bg"
        android:orientation="vertical"
        android:paddingHorizontal="14dp"
        android:paddingVertical="14dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:text="@string/qr_code_tool_scan_result_label"
            android:textColor="#9900FF88"
            android:textSize="10sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_scan_result_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:fontFamily="monospace"
            android:lineSpacingExtra="4dp"
            android:textColor="#E6FFFFFF"
            android:textIsSelectable="true"
            android:textSize="14sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/btn_copy_result"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginTop="18dp"
        android:background="@drawable/qr_tool_primary_action_bg"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground"
        android:fontFamily="monospace"
        android:gravity="center"
        android:text="@string/qr_code_tool_copy_result"
        android:textColor="#08121A"
        android:textSize="14sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/btn_dismiss_result"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/qr_tool_secondary_action_bg"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground"
        android:fontFamily="monospace"
        android:gravity="center"
        android:text="@android:string/ok"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:textStyle="bold" />

</LinearLayout>
