<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android">
<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F1118"
    android:fitsSystemWindows="true"
    android:orientation="vertical">

    <!-- ─── Header ─── -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:background="#161A26"
        android:gravity="center_vertical">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:layout_marginStart="4dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/history_cancel"
            android:src="?attr/homeAsUpIndicator" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:letterSpacing="0.25"
            android:text="@string/about_aircraft_title"
            android:textColor="#00FF88"
            android:textSize="16sp"
            android:textStyle="bold"
            android:typeface="monospace" />
    </RelativeLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#4400FF88" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:overScrollMode="never"
        android:paddingBottom="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="14dp">

            <!-- ════════════════════════════════════════════════
                 PROJECT BANNER
                 ════════════════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/device_info_card_bg"
                android:orientation="vertical"
                android:paddingHorizontal="18dp"
                android:paddingVertical="16dp">

                <TextView
                    android:id="@+id/tv_project_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/app_name"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:typeface="monospace" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tv_version_badge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/device_info_gauge_bg"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="3dp"
                        android:textColor="#00FF88"
                        android:textSize="11sp"
                        android:typeface="monospace" />

                    <TextView
                        android:id="@+id/tv_platform_badge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/device_info_gauge_bg"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="3dp"
                        android:textColor="#88FFFFFF"
                        android:textSize="11sp"
                        android:typeface="monospace" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/device_info_gauge_bg"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="3dp"
                        android:text="Kotlin"
                        android:textColor="#88FFFFFF"
                        android:textSize="11sp"
                        android:typeface="monospace" />
                </LinearLayout>
            </LinearLayout>

            <!-- ════════════════════════════════════════════════
                 PROJECT IMAGE
                 ════════════════════════════════════════════════ -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/device_info_card_bg"
                android:padding="2dp">

                <ProgressBar
                    android:id="@+id/progress_image"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="60dp"
                    android:layout_marginBottom="60dp" />

                <ImageView
                    android:id="@+id/iv_project"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:adjustViewBounds="true"
                    android:contentDescription="@string/about_aircraft_title" />
            </FrameLayout>

            <!-- ════════════════════════════════════════════════
                 SECTION: OVERVIEW
                 ════════════════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <View
                    android:layout_width="3dp"
                    android:layout_height="14dp"
                    android:background="#00FF88" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:letterSpacing="0.2"
                    android:text="@string/about_section_overview"
                    android:textColor="#66FFFFFF"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:typeface="monospace" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/device_info_card_bg"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                android:paddingVertical="14dp">

                <TextView
                    android:id="@+id/tv_description"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:lineSpacingExtra="4dp"
                    android:textColor="#CDD2E0"
                    android:textSize="13sp"
                    android:typeface="monospace" />
            </LinearLayout>

            <!-- ════════════════════════════════════════════════
                 SECTION: GAME SPECS
                 ════════════════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <View
                    android:layout_width="3dp"
                    android:layout_height="14dp"
                    android:background="#00FF88" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:letterSpacing="0.2"
                    android:text="@string/about_section_specs"
                    android:textColor="#66FFFFFF"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:typeface="monospace" />
            </LinearLayout>

            <!-- Stats row: Levels / Enemies / Bosses -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:baselineAligned="false"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="4dp"
                    android:layout_weight="1"
                    android:background="@drawable/device_info_card_bg"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:letterSpacing="0.15"
                        android:text="@string/about_stat_levels"
                        android:textColor="#88FFFFFF"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:typeface="monospace" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="10"
                        android:textColor="#00FF88"
                        android:textSize="26sp"
                        android:textStyle="bold"
                        android:typeface="monospace" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="4dp"
                    android:layout_weight="1"
                    android:background="@drawable/device_info_card_bg"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:letterSpacing="0.15"
                        android:text="@string/about_stat_enemies"
                        android:textColor="#88FFFFFF"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:typeface="monospace" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="15"
                        android:textColor="#00FF88"
                        android:textSize="26sp"
                        android:textStyle="bold"
                        android:typeface="monospace" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:layout_weight="1"
                    android:background="@drawable/device_info_card_bg"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:letterSpacing="0.15"
                        android:text="@string/about_stat_jets"
                        android:textColor="#88FFFFFF"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:typeface="monospace" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="4"
                        android:textColor="#00FF88"
                        android:textSize="26sp"
                        android:textStyle="bold"
                        android:typeface="monospace" />
                </LinearLayout>
            </LinearLayout>

            <!-- Key-value detail card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/device_info_card_bg"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                android:paddingVertical="4dp">

                <!-- Engine -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingVertical="11dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/about_spec_engine"
                        android:textColor="#88FFFFFF"
                        android:textSize="12sp"
                        android:typeface="monospace" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/about_spec_engine_val"
                        android:textColor="#CDD2E0"
                        android:textSize="12sp"
                        android:typeface="monospace" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#10FFFFFF" />

                <!-- FPS -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingVertical="11dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/about_spec_fps"
                        android:textColor="#88FFFFFF"
                        android:textSize="12sp"
                        android:typeface="monospace" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/about_spec_fps_val"
                        android:textColor="#00FF88"
                        android:textSize="12sp"
                        android:typeface="monospace" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#10FFFFFF" />

                <!-- Difficulty -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingVertical="11dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/about_spec_difficulty"
                        android:textColor="#88FFFFFF"
                        android:textSize="12sp"
                        android:typeface="monospace" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/about_spec_difficulty_val"
                        android:textColor="#CDD2E0"
                        android:textSize="12sp"
                        android:typeface="monospace" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#10FFFFFF" />

                <!-- Power-ups -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingVertical="11dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/about_spec_powerups"
                        android:textColor="#88FFFFFF"
                        android:textSize="12sp"
                        android:typeface="monospace" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/about_spec_powerups_val"
                        android:textColor="#CDD2E0"
                        android:textSize="12sp"
                        android:typeface="monospace" />
                </LinearLayout>
            </LinearLayout>

            <!-- ════════════════════════════════════════════════
                 SECTION: SOURCE CODE
                 ════════════════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <View
                    android:layout_width="3dp"
                    android:layout_height="14dp"
                    android:background="#00FF88" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:letterSpacing="0.2"
                    android:text="@string/about_section_source"
                    android:textColor="#66FFFFFF"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:typeface="monospace" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/ll_github_link"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/device_info_card_bg"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:paddingVertical="14dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/about_github_label"
                    android:textColor="#88FFFFFF"
                    android:textSize="12sp"
                    android:typeface="monospace" />

                <TextView
                    android:id="@+id/tv_github_url"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#00FF88"
                    android:textSize="12sp"
                    android:typeface="monospace" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
</layout>
