<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    tools:context=".gui.PrivacyPolicyAcceptActivity">

    <!-- Animated star field background (z=0) -->
    <com.young.aircraft.gui.StarFieldView
        android:id="@+id/star_field"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Content overlay (z=1) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Header -->
        <RelativeLayout
            style="@style/GameHeader"
            android:gravity="center_vertical">

            <TextView
                style="@style/GameHeaderTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:gravity="center"
                android:text="@string/mission_briefing_title" />
        </RelativeLayout>

        <View style="@style/NeonDivider" />

        <!-- Translucent card with WebView -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginHorizontal="12dp"
            android:layout_marginVertical="8dp"
            android:background="@drawable/translucent_card_bg">

            <WebView
                android:id="@+id/web_view"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_margin="1dp" />
        </FrameLayout>

        <View style="@style/NeonDivider" />

        <!-- Bottom buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="#161A26"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp">

            <TextView
                android:id="@+id/btn_accept"
                style="@style/TacticalButton.Accept"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:alpha="0.3"
                android:contentDescription="@string/privacy_policy_accept"
                android:enabled="false" />

            <TextView
                android:id="@+id/btn_reject"
                style="@style/TacticalButton.Reject"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:alpha="0.3"
                android:contentDescription="@string/privacy_policy_reject"
                android:enabled="false" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
