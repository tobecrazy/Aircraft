<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="32dp">

    <TextView
        style="@style/GameHeaderTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="32dp"
        android:text="@string/onboarding_powerups_title" />

    <!-- Heart = HP Restore -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginEnd="16dp"
            android:contentDescription="@string/onboarding_hp_restore"
            android:src="@drawable/red_heart_1" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/onboarding_hp_restore"
            android:textColor="#CCFFFFFF"
            android:textSize="15sp"
            android:typeface="monospace" />
    </LinearLayout>

    <!-- Shield = Invincibility -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginEnd="16dp"
            android:contentDescription="@string/onboarding_invincibility"
            android:src="@drawable/shield_1" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/onboarding_invincibility"
            android:textColor="#CCFFFFFF"
            android:textSize="15sp"
            android:typeface="monospace" />
    </LinearLayout>

    <!-- Gift box = AoE Rocket -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginEnd="16dp"
            android:contentDescription="@string/onboarding_aoe_rocket"
            android:src="@drawable/red_box_1" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/onboarding_aoe_rocket"
            android:textColor="#CCFFFFFF"
            android:textSize="15sp"
            android:typeface="monospace" />
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/onboarding_collect_all"
        android:textColor="#00FF88"
        android:textSize="16sp"
        android:textStyle="bold"
        android:typeface="monospace" />
</LinearLayout>
