<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/dialog_background"
    android:orientation="vertical"
    android:paddingHorizontal="24dp"
    android:paddingTop="24dp"
    android:paddingBottom="20dp">

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:letterSpacing="0.15"
        android:text="@string/difficulty_title"
        android:textColor="#00FF88"
        android:textSize="20sp"
        android:textStyle="bold"
        android:typeface="monospace" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="18dp"
        android:background="#4400FF88" />

    <!-- ── Easy ── -->
    <LinearLayout
        android:id="@+id/option_easy"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/difficulty_option_bg"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingVertical="14dp">

        <View
            android:id="@+id/indicator_easy"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@drawable/difficulty_indicator_easy" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/difficulty_easy"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:typeface="monospace" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/difficulty_easy_desc"
                android:textColor="#66FFFFFF"
                android:textSize="11sp"
                android:typeface="monospace" />
        </LinearLayout>

        <TextView
            android:id="@+id/badge_easy"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/badge_easy"
            android:paddingHorizontal="10dp"
            android:paddingVertical="3dp"
            android:text="1.2x"
            android:textColor="#00FF88"
            android:textSize="11sp"
            android:textStyle="bold"
            android:typeface="monospace" />
    </LinearLayout>

    <!-- ── Normal ── -->
    <LinearLayout
        android:id="@+id/option_normal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/difficulty_option_bg"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingVertical="14dp">

        <View
            android:id="@+id/indicator_normal"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@drawable/difficulty_indicator_normal" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/difficulty_normal"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:typeface="monospace" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/difficulty_normal_desc"
                android:textColor="#66FFFFFF"
                android:textSize="11sp"
                android:typeface="monospace" />
        </LinearLayout>

        <TextView
            android:id="@+id/badge_normal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/badge_normal"
            android:paddingHorizontal="10dp"
            android:paddingVertical="3dp"
            android:text="1.0x"
            android:textColor="#FFFF00"
            android:textSize="11sp"
            android:textStyle="bold"
            android:typeface="monospace" />
    </LinearLayout>

    <!-- ── Hard ── -->
    <LinearLayout
        android:id="@+id/option_hard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/difficulty_option_bg"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingVertical="14dp">

        <View
            android:id="@+id/indicator_hard"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@drawable/difficulty_indicator_hard" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/difficulty_hard"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:typeface="monospace" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/difficulty_hard_desc"
                android:textColor="#66FFFFFF"
                android:textSize="11sp"
                android:typeface="monospace" />
        </LinearLayout>

        <TextView
            android:id="@+id/badge_hard"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/badge_hard"
            android:paddingHorizontal="10dp"
            android:paddingVertical="3dp"
            android:text="0.8x"
            android:textColor="#FF4444"
            android:textSize="11sp"
            android:textStyle="bold"
            android:typeface="monospace" />
    </LinearLayout>

    <!-- Current selection indicator -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:gravity="center"
        android:orientation="horizontal">

        <View
            android:id="@+id/current_indicator_dot"
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:background="@drawable/difficulty_indicator_normal" />

        <TextView
            android:id="@+id/current_selection_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:letterSpacing="0.1"
            android:textColor="#88FFFFFF"
            android:textSize="11sp"
            android:typeface="monospace" />
    </LinearLayout>
</LinearLayout>
