<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android">

    <data />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#0F1118"
        android:fitsSystemWindows="true"
        android:orientation="vertical">

        <!-- ─── Header ─── -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="#161A26"
            android:gravity="center_vertical">

            <ImageButton
                android:id="@+id/btn_back"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:layout_marginStart="4dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/history_cancel"
                android:src="?attr/homeAsUpIndicator" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:letterSpacing="0.25"
                android:text="@string/title_activity_settings"
                android:textColor="#00FF88"
                android:textSize="16sp"
                android:textStyle="bold"
                android:typeface="monospace" />
        </RelativeLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#4400FF88" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:overScrollMode="never"
            android:paddingBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="14dp">

                <!-- ════════════════════════════════════
                     SECTION: DIFFICULTY
                     ════════════════════════════════════ -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <View
                        android:layout_width="3dp"
                        android:layout_height="14dp"
                        android:background="#00FF88" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:letterSpacing="0.2"
                        android:text="@string/difficulty_settings_header"
                        android:textColor="#66FFFFFF"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:typeface="monospace" />
                </LinearLayout>

                <!-- Difficulty selector card -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/device_info_card_bg"
                    android:orientation="vertical"
                    android:paddingHorizontal="6dp"
                    android:paddingVertical="10dp">

                    <!-- Three difficulty buttons side by side -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:baselineAligned="false"
                        android:orientation="horizontal">

                        <!-- Easy -->
                        <LinearLayout
                            android:id="@+id/option_easy"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginHorizontal="4dp"
                            android:layout_weight="1"
                            android:background="@drawable/difficulty_option_bg"
                            android:gravity="center_horizontal"
                            android:orientation="vertical"
                            android:paddingHorizontal="8dp"
                            android:paddingVertical="14dp">

                            <View
                                android:layout_width="8dp"
                                android:layout_height="8dp"
                                android:background="@drawable/difficulty_indicator_easy" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:text="@string/difficulty_easy"
                                android:textColor="#FFFFFF"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:typeface="monospace" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:background="@drawable/badge_easy"
                                android:paddingHorizontal="8dp"
                                android:paddingVertical="2dp"
                                android:text="1.2x"
                                android:textColor="#00FF88"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:typeface="monospace" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:gravity="center"
                                android:text="@string/difficulty_easy_desc"
                                android:textColor="#55FFFFFF"
                                android:textSize="9sp"
                                android:typeface="monospace" />
                        </LinearLayout>

                        <!-- Normal -->
                        <LinearLayout
                            android:id="@+id/option_normal"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginHorizontal="4dp"
                            android:layout_weight="1"
                            android:background="@drawable/difficulty_option_bg"
                            android:gravity="center_horizontal"
                            android:orientation="vertical"
                            android:paddingHorizontal="8dp"
                            android:paddingVertical="14dp">

                            <View
                                android:layout_width="8dp"
                                android:layout_height="8dp"
                                android:background="@drawable/difficulty_indicator_normal" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:text="@string/difficulty_normal"
                                android:textColor="#FFFFFF"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:typeface="monospace" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:background="@drawable/badge_normal"
                                android:paddingHorizontal="8dp"
                                android:paddingVertical="2dp"
                                android:text="1.0x"
                                android:textColor="#FFFF00"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:typeface="monospace" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:gravity="center"
                                android:text="@string/difficulty_normal_desc"
                                android:textColor="#55FFFFFF"
                                android:textSize="9sp"
                                android:typeface="monospace" />
                        </LinearLayout>

                        <!-- Hard -->
                        <LinearLayout
                            android:id="@+id/option_hard"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginHorizontal="4dp"
                            android:layout_weight="1"
                            android:background="@drawable/difficulty_option_bg"
                            android:gravity="center_horizontal"
                            android:orientation="vertical"
                            android:paddingHorizontal="8dp"
                            android:paddingVertical="14dp">

                            <View
                                android:layout_width="8dp"
                                android:layout_height="8dp"
                                android:background="@drawable/difficulty_indicator_hard" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:text="@string/difficulty_hard"
                                android:textColor="#FFFFFF"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:typeface="monospace" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:background="@drawable/badge_hard"
                                android:paddingHorizontal="8dp"
                                android:paddingVertical="2dp"
                                android:text="0.8x"
                                android:textColor="#FF4444"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:typeface="monospace" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:gravity="center"
                                android:text="@string/difficulty_hard_desc"
                                android:textColor="#55FFFFFF"
                                android:textSize="9sp"
                                android:typeface="monospace" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Current active indicator -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:gravity="center"
                        android:orientation="horizontal"
                        android:paddingHorizontal="10dp">

                        <View
                            android:id="@+id/current_indicator_dot"
                            android:layout_width="6dp"
                            android:layout_height="6dp"
                            android:background="@drawable/difficulty_indicator_normal" />

                        <TextView
                            android:id="@+id/current_selection_label"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:letterSpacing="0.1"
                            android:textColor="#88FFFFFF"
                            android:textSize="10sp"
                            android:typeface="monospace" />
                    </LinearLayout>
                </LinearLayout>

                <!-- ════════════════════════════════════
                     SECTION: SOUND
                     ════════════════════════════════════ -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="22dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <View
                        android:layout_width="3dp"
                        android:layout_height="14dp"
                        android:background="#00FF88" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:letterSpacing="0.2"
                        android:text="@string/sound_settings_header"
                        android:textColor="#66FFFFFF"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:typeface="monospace" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/device_info_card_bg"
                    android:orientation="vertical"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="4dp">

                    <!-- Background Music toggle -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingVertical="14dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/background_sound_title"
                                android:textColor="#FFFFFF"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:typeface="monospace" />

                            <TextView
                                android:id="@+id/tv_bg_sound_status"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:textColor="#55FFFFFF"
                                android:textSize="11sp"
                                android:typeface="monospace" />
                        </LinearLayout>

                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/switch_bg_sound"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:thumb="@drawable/switch_thumb"
                            android:track="@drawable/switch_track" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#10FFFFFF" />

                    <!-- Combat Sound toggle -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingVertical="14dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/combat_sound_title"
                                android:textColor="#FFFFFF"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:typeface="monospace" />

                            <TextView
                                android:id="@+id/tv_combat_sound_status"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:textColor="#55FFFFFF"
                                android:textSize="11sp"
                                android:typeface="monospace" />
                        </LinearLayout>

                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/switch_combat_sound"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:thumb="@drawable/switch_thumb"
                            android:track="@drawable/switch_track" />
                    </LinearLayout>
                </LinearLayout>

                <!-- ════════════════════════════════════
                     SECTION: OTHER
                     ════════════════════════════════════ -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="22dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <View
                        android:layout_width="3dp"
                        android:layout_height="14dp"
                        android:background="#00FF88" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:letterSpacing="0.2"
                        android:text="@string/other_settings_header"
                        android:textColor="#66FFFFFF"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:typeface="monospace" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/device_info_card_bg"
                    android:orientation="vertical"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="4dp">

                    <!-- Device Information -->
                    <LinearLayout
                        android:id="@+id/row_device_info"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/settings_row_bg"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingVertical="14dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/device_info_title"
                                android:textColor="#FFFFFF"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:typeface="monospace" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="@string/device_info_summary"
                                android:textColor="#55FFFFFF"
                                android:textSize="11sp"
                                android:typeface="monospace" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="›"
                            android:textColor="#4400FF88"
                            android:textSize="22sp"
                            android:typeface="monospace" />
                    </LinearLayout>

                    <View
                        android:id="@+id/divider_develop_settings"
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#10FFFFFF"
                        android:visibility="gone" />

                    <LinearLayout
                        android:id="@+id/row_develop_settings"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/settings_row_bg"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingVertical="14dp"
                        android:visibility="gone">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/develop_settings_title"
                                android:textColor="#FFFFFF"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:typeface="monospace" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="@string/develop_settings_summary"
                                android:textColor="#55FFFFFF"
                                android:textSize="11sp"
                                android:typeface="monospace" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="›"
                            android:textColor="#4400FF88"
                            android:textSize="22sp"
                            android:typeface="monospace" />
                    </LinearLayout>
                </LinearLayout>

                <!-- ════════════════════════════════════
                     SECTION: ABOUT US
                     ════════════════════════════════════ -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="22dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <View
                        android:layout_width="3dp"
                        android:layout_height="14dp"
                        android:background="#00FF88" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:letterSpacing="0.2"
                        android:text="@string/about_us_title"
                        android:textColor="#66FFFFFF"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:typeface="monospace" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/device_info_card_bg"
                    android:orientation="vertical"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="4dp">

                    <!-- About Aircraft -->
                    <LinearLayout
                        android:id="@+id/row_about_aircraft"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/settings_row_bg"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingVertical="14dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/about_aircraft_title"
                                android:textColor="#FFFFFF"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:typeface="monospace" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="@string/about_aircraft_summary"
                                android:textColor="#55FFFFFF"
                                android:textSize="11sp"
                                android:typeface="monospace" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="›"
                            android:textColor="#4400FF88"
                            android:textSize="22sp"
                            android:typeface="monospace" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#10FFFFFF" />

                    <!-- Privacy Policy -->
                    <LinearLayout
                        android:id="@+id/row_privacy_policy"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/settings_row_bg"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingVertical="14dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/privacy_policy_title"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:typeface="monospace" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="›"
                            android:textColor="#4400FF88"
                            android:textSize="22sp"
                            android:typeface="monospace" />
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>
        </ScrollView>
    </LinearLayout>
</layout>
