<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <gradient
                android:angle="0"
                android:endColor="#25354A"
                android:startColor="#304761" />
            <stroke
                android:width="1dp"
                android:color="#5500FF88" />
            <corners android:radius="18dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="0"
                android:endColor="#1B2531"
                android:startColor="#22303F" />
            <stroke
                android:width="1dp"
                android:color="#3300FF88" />
            <corners android:radius="18dp" />
        </shape>
    </item>
</selector>
