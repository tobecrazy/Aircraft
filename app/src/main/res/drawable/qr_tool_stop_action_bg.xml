<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <gradient
                android:angle="0"
                android:endColor="#B84B4B"
                android:startColor="#E97E7E" />
            <stroke
                android:width="1dp"
                android:color="#66FF9F9F" />
            <corners android:radius="18dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="0"
                android:endColor="#913737"
                android:startColor="#D46262" />
            <stroke
                android:width="1dp"
                android:color="#55FF9F9F" />
            <corners android:radius="18dp" />
        </shape>
    </item>
</selector>
