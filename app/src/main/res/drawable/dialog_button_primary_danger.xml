<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <gradient
                android:angle="0"
                android:endColor="#CC4400"
                android:startColor="#FF6B3D" />
            <stroke
                android:width="1dp"
                android:color="#99FFB4A0" />
            <corners android:radius="12dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="0"
                android:endColor="#E05530"
                android:startColor="#FF8A65" />
            <stroke
                android:width="1dp"
                android:color="#CCFFE0D0" />
            <corners android:radius="12dp" />
        </shape>
    </item>
</selector>
