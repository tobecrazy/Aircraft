<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <gradient
                android:angle="0"
                android:endColor="#00CC66"
                android:startColor="#27F29F" />
            <stroke
                android:width="1dp"
                android:color="#99B4FFD7" />
            <corners android:radius="12dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="0"
                android:endColor="#00D87D"
                android:startColor="#6AFFC2" />
            <stroke
                android:width="1dp"
                android:color="#CCDBFFEF" />
            <corners android:radius="12dp" />
        </shape>
    </item>
</selector>
